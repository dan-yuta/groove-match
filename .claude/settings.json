  "shikigaku": {
    "principles": [
      "責任と権限の明確化",
      "結果重視",
      "階層の明確化",
      "誤解・錯覚の排除",
      "感情的判断の排除"
    ],
    "labels": 60,
    "hierarchy": "Human → Coordinator → Specialist"
  },
  "hooks": {
    "SessionStart": [
      {
        "matcher": "startup",
        "hooks": [
          {
            "type": "command",
            "command": ".claude/hooks/session-start.sh",
            "timeout": 30
          },
          {
            "type": "command",
            "command": ".claude/hooks/ccmvec-search.sh groove-match",
            "timeout": 30
          },
          {
            "type": "command",
            "command": ".claude/hooks/agent-pipeline-guide.sh",
            "timeout": 5
          }
        ]
      }
    ],
    "SessionEnd": [
      {
        "hooks": [
          {
            "type": "command",
            "command": ".claude/hooks/session-end.sh",
            "timeout": 30
          }
        ]
      }
    ],
    "PreToolUse": [
      {
        "matcher": "Bash",
        "hooks": [
          {
            "type": "command",
            "command": ".claude/hooks/git-ops-validator.sh",
            "timeout": 10
          }
        ]
      }
    ],
    "PostToolUse": [
      {
        "matcher": "Task",
        "hooks": [
          {
            "type": "command",
            "command": ".claude/hooks/agent-logger.sh",
            "timeout": 30
          },
          {
            "type": "command",
            "command": ".claude/hooks/codegen-review-trigger.sh",
            "timeout": 10
          }
        ]
      },
      {
        "matcher": "Write",
        "hooks": [
          {
            "type": "command",
            "command": ".claude/hooks/feedback-ssot-sync.sh",
            "timeout": 30
          }
        ]
      },
      {
        "matcher": "Edit",
        "hooks": [
          {
            "type": "command",
            "command": ".claude/hooks/format-check.sh",
            "timeout": 10
          }
        ]
      }
    ]
  }
}
